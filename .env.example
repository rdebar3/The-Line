# Clerk — https://dashboard.clerk.com
# Use pk_live_ / sk_live_ keys in production. Add your domain under Clerk → Domains.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# xAI Grok — https://console.x.ai
XAI_API_KEY=xai-...

# Stripe — https://dashboard.stripe.com
# Test keys for preview; live keys (sk_live_) for production.
# Webhook endpoint: https://your-domain.com/api/purchase/webhook
# Event to listen for: checkout.session.completed
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Production URL (required for Stripe redirects, sitemap, OpenGraph)
NEXT_PUBLIC_APP_URL=https://the-line-eight.vercel.app

# Upstash Redis — leaderboard, cloud save, server-side daily usage limits
# Required for enforcing free-tier Grok/scenario caps in production.
UPSTASH_REDIS_REST_URL=https://....upstash.io
UPSTASH_REDIS_REST_TOKEN=...